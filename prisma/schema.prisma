// TOOLDECK — Prisma schema (SQLite)
// M1 · Foundation: User model only (auth via NextAuth credentials provider).
// The full §5 inventory schema (locations, categories, items, transactions,
// maintenance_logs) arrives in M2. The User model here stands in for Supabase's
// `auth.users` + `profiles` (decision 1a: local stack mirror of the spec).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  fullName     String
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
